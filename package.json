{
  "name": "react-example",
  "private": true,
  "version": "0.1.0",
  "description": "TCM classical text relation graph desktop app",
  "author": "Codex",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "node server/dev-server.mjs",
    "dev:web:desktop": "vite --mode desktop --port=3100 --host=0.0.0.0 --strictPort",
    "dev:api:desktop": "node server/dev-server.mjs 3101",
    "dev:electron": "wait-on tcp:3100 tcp:3101 && electron .",
    "desktop:dev": "concurrently -k \"npm:dev:api:desktop\" \"npm:dev:web:desktop\" \"npm:dev:electron\"",
    "build": "vite build",
    "assets:desktop": "powershell -ExecutionPolicy Bypass -File scripts/generate-desktop-icon.ps1",
    "build:desktop": "npm run assets:desktop && npm run build && electron-builder --win nsis",
    "build:desktop:dir": "npm run assets:desktop && npm run build && electron-builder --win dir",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "import:shanghan": "tsx scripts/import-shanghan.ts",
    "import:jingui": "tsx scripts/import-jingui.ts",
    "import:wenbing": "tsx scripts/import-wenbing.ts",
    "data:audit": "tsx scripts/data-audit.ts",
    "db:init": "tsx scripts/init-db.ts",
    "db:import:shanghan": "tsx scripts/import-shanghan-db.ts",
    "db:import:jingui": "tsx scripts/import-jingui-db.ts",
    "db:import:wenbing": "tsx scripts/import-wenbing-db.ts",
    "db:import:relations": "tsx scripts/import-relations-db.ts",
    "db:seed": "npm run db:init && npm run db:import:shanghan && npm run db:import:jingui && npm run db:import:wenbing && npm run db:import:relations",
    "db:sync": "tsx scripts/sync-db.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.jingfangxingtu.desktop",
    "productName": "经方关系图",
    "executableName": "JingfangRelations",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "asar": true,
    "files": [
      "dist/**/*",
      "assets/**/*",
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "bundled/data"
      },
      {
        "from": "storage/app.db",
        "to": "bundled/storage/app.db"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/desktop/icon.ico",
      "legalTrademarks": "Jingfang Relations",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "经方关系图",
      "installerIcon": "assets/desktop/icon.ico",
      "uninstallerIcon": "assets/desktop/icon.ico"
    }
  }
}
